# Ghostty configuration — Chrysaki theme
# Static settings; colors are imported from ~/.config/ghostty/colors
# (regenerated by ghostty/scripts/update_colors.py on palette change)

# Import generated color file
config-file = ~/.config/ghostty/colors

# --- Font ---
font-family = IosevkaTermSlab Nerd Font
font-size = 10
font-feature = calt
font-feature = liga
font-feature = zero

# --- Cursor ---
cursor-style = block
cursor-style-blink = true

# --- Window ---
window-padding-x = 0
window-padding-y = 0
window-padding-balance = true
background-opacity = 0.96
background-blur-radius = 20
window-decoration = false
gtk-titlebar = false
window-theme = ghostty

# --- Scrollback ---
scrollback-limit = 10000

# --- Clipboard ---
copy-on-select = clipboard

# --- Text rendering ---
bold-is-bright = false
minimum-contrast = 1.1

# --- UX ---
mouse-hide-while-typing = true
resize-overlay = never
unfocused-split-opacity = 0.75
shell-integration = detect

# --- Shader: film grain + vignette + scanlines ---
custom-shader = ~/.config/ghostty/shaders/grain.glsl
custom-shader-animation = always

# --- Keybinds ---
# Word navigation — send CSI sequences; zsh binds them to word widgets
keybind = ctrl+left=csi:1;5D
keybind = ctrl+right=csi:1;5C
# Word delete — send CSI sequence; zsh binds it to backward-kill-word
keybind = ctrl+backspace=csi:127;5u
keybind = shift+enter=text:\n
