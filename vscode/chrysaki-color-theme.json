  "semanticTokenColors": {
    "comment": { "foreground": "#7d8298", "fontStyle": "italic" },
    "keyword": "#9973cf",
    "keyword.control": "#9973cf",
    "storage": "#9973cf",
    "storage.type": "#9973cf",
    "storage.modifier": "#9973cf",
    "modifier": "#9973cf",
    "function": "#22a37e",
    "function.declaration": "#22a37e",
    "method": "#22a37e",
    "method.declaration": "#22a37e",
    "macro": "#9973cf",
    "decorator": "#9973cf",
    "variable": "#27b2b9",
    "variable.readonly": "#FCC96A",
    "parameter": "#27b2b9",
    "property": "#eaecf4",
    "property.declaration": "#eaecf4",
    "type": "#27b2b9",
    "class": "#27b2b9",
    "struct": "#27b2b9",
    "interface": "#27b2b9",
    "enum": "#27b2b9",
    "enumMember": "#FCC96A",
    "typeParameter": "#27b2b9",
    "namespace": "#27b2b9",
    "string": "#FBB13C",
    "number": "#FBB13C",
    "regexp": "#FCC96A",
    "operator": "#b0b4c8",
    "*.readonly": "#FCC96A",
    "selfKeyword": "#9973cf",
    "builtinConstant": "#FBB13C"
  },
  "tokenColors": [
    {
      "name": "Comment",
      "scope": ["comment", "punctuation.definition.comment", "string.comment"],
      "settings": { "foreground": "#7d8298", "fontStyle": "italic" }
    },
    {
      "name": "Keyword / Control Flow / import-from-const-return-def-for-in",
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.control.flow",
        "keyword.control.import",
        "keyword.control.from",
        "keyword.control.loop",
        "keyword.control.conditional",
        "keyword.other.using",
        "keyword.other.directive",
        "keyword.package",
        "keyword.import"
      ],
      "settings": { "foreground": "#9973cf" }
    },
    {
      "name": "Storage / storage type / modifiers",
      "scope": ["storage", "storage.type", "storage.modifier", "keyword.declaration"],
      "settings": { "foreground": "#9973cf" }
    },
    {
      "name": "Function / Method / support function",
      "scope": [
        "entity.name.function",
        "meta.function-call",
        "meta.function-call entity.name.function",
        "support.function",
        "meta.definition.method entity.name.function"
      ],
      "settings": { "foreground": "#22a37e" }
    },
    {
      "name": "Tag name (HTML/JSX/XML)",
      "scope": ["entity.name.tag", "support.class.component"],
      "settings": { "foreground": "#22a37e" }
    },
    {
      "name": "Type / Class / interface / struct / namespace",
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "entity.other.inherited-class",
        "support.type",
        "support.class",
        "entity.name.namespace",
        "entity.name.module",
        "meta.type.name",
        "storage.type.built-in"
      ],
      "settings": { "foreground": "#27b2b9" }
    },
    {
      "name": "Variable / other variable",
      "scope": ["variable", "variable.other", "variable.other.readwrite", "meta.variable"],
      "settings": { "foreground": "#27b2b9" }
    },
    {
      "name": "Parameter",
      "scope": ["variable.parameter", "meta.parameter", "variable.parameter.function"],
      "settings": { "foreground": "#27b2b9" }
    },
    {
      "name": "Property / object key (default text stays fg1)",
      "scope": [
        "variable.other.property",
        "variable.other.object.property",
        "meta.object-literal.key",
        "support.type.property-name",
        "support.variable.property"
      ],
      "settings": { "foreground": "#eaecf4" }
    },
    {
      "name": "String / attribute values",
      "scope": [
        "string",
        "string.quoted",
        "string.template",
        "string.unquoted",
        "meta.attribute-selector",
        "string.other.link"
      ],
      "settings": { "foreground": "#FBB13C" }
    },
    {
      "name": "Number / numeric value / hex color literal",
      "scope": [
        "constant.numeric",
        "constant.other.color",
        "constant.other.color.rgb-value",
        "constant.numeric.hex"
      ],
      "settings": { "foreground": "#FBB13C" }
    },
    {
      "name": "Constant / language / builtin constants",
      "scope": [
        "constant.language",
        "constant.language.boolean",
        "constant.language.null",
        "support.constant",
        "variable.other.constant",
        "variable.language",
        "support.function.builtin"
      ],
      "settings": { "foreground": "#FBB13C" }
    },
    {
      "name": "Escape Character / regexp",
      "scope": ["constant.character.escape", "string.regexp", "constant.other.character-class"],
      "settings": { "foreground": "#FCC96A" }
    },
    {
      "name": "Operator",
      "scope": ["keyword.operator", "keyword.operator.arithmetic", "keyword.operator.logical", "storage.type.function.arrow"],
      "settings": { "foreground": "#b0b4c8" }
    },
    {
      "name": "Punctuation / braces / delimiters",
      "scope": [
        "punctuation",
        "meta.brace",
        "punctuation.separator",
        "punctuation.terminator",
        "punctuation.definition.block",
        "punctuation.section",
        "meta.delimiter"
      ],
      "settings": { "foreground": "#b0b4c8" }
    },
    {
      "name": "HTML/XML attribute name",
      "scope": ["entity.other.attribute-name", "entity.other.attribute-name.html"],
      "settings": { "foreground": "#27b2b9" }
    },
    {
      "name": "CSS property name (default fg1)",
      "scope": ["support.type.property-name.css", "meta.property-name.css"],
      "settings": { "foreground": "#eaecf4" }
    },
    {
      "name": "CSS units / at-rules / :root and selectors keyword",
      "scope": [
        "keyword.other.unit",
        "keyword.control.at-rule",
        "punctuation.definition.keyword.css",
        "entity.other.keyframe-selector.css"
      ],
      "settings": { "foreground": "#27b2b9" }
    },
    {
      "name": "CSS entity selector (:root, tag, class, id) as keyword-like structure",
      "scope": ["entity.name.tag.css", "entity.name.tag.reference.css"],
      "settings": { "foreground": "#9973cf" }
    },
    {
      "name": "CSS string value / color name",
      "scope": ["support.constant.property-value.css", "support.constant.color.w3c-standard-color-name.css"],
      "settings": { "foreground": "#FBB13C" }
    },
    {
      "name": "Decorator / Annotation",
      "scope": [
        "meta.decorator",
        "punctuation.decorator",
        "entity.name.function.decorator",
        "meta.annotation",
        "storage.type.annotation"
      ],
      "settings": { "foreground": "#9973cf" }
    },
    {
      "name": "Invalid / Illegal",
      "scope": ["invalid", "invalid.illegal"],
      "settings": { "foreground": "#b53f4a" }
    },
    {
      "name": "Invalid / Deprecated",
      "scope": ["invalid.deprecated"],
      "settings": { "foreground": "#C4861C", "fontStyle": "italic" }
    },
    {
      "name": "Markup Heading (h1 = emerald)",
      "scope": ["markup.heading", "entity.name.section", "markup.heading.markdown"],
      "settings": { "foreground": "#22a37e", "fontStyle": "bold" }
    },
    {
      "name": "Markup Bold",
      "scope": ["markup.bold"],
      "settings": { "foreground": "#FBB13C", "fontStyle": "bold" }
    },
    {
