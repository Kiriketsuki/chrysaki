    "gitDecoration.untrackedResourceForeground": "#2aaab8",
    "gitDecoration.ignoredResourceForeground": "#6a6e82"
  },
  "tokenColors": [
    {
      "name": "Comment",
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": {
        "foreground": "#6a6e82",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Keyword / Control Flow",
      "scope": ["keyword", "keyword.control", "storage.modifier", "keyword.other.using", "keyword.other.directive"],
      "settings": {
        "foreground": "#583090"
      }
    },
    {
      "name": "Storage Type",
      "scope": ["storage", "storage.type"],
      "settings": {
        "foreground": "#583090"
      }
    },
    {
      "name": "Function / Method",
      "scope": ["entity.name.function", "meta.function-call", "support.function"],
      "settings": {
        "foreground": "#1a8a6a"
      }
    },
    {
      "name": "Type / Class",
      "scope": ["entity.name.type", "entity.name.class", "entity.other.inherited-class", "support.type", "support.class"],
      "settings": {
        "foreground": "#2aaab8"
      }
    },
    {
      "name": "Variable",
      "scope": ["variable", "variable.other"],
      "settings": {
        "foreground": "#e0e2ea"
      }
    },
    {
      "name": "Parameter",
      "scope": ["variable.parameter"],
      "settings": {
        "foreground": "#2aaab8"
      }
    },
    {
      "name": "String",
      "scope": ["string", "string.quoted"],
      "settings": {
        "foreground": "#b8a038"
      }
    },
    {
      "name": "Number",
      "scope": ["constant.numeric"],
      "settings": {
        "foreground": "#d0b850"
      }
    },
    {
      "name": "Constant / Builtin",
      "scope": ["constant.other", "constant.language", "support.constant", "variable.other.constant"],
      "settings": {
        "foreground": "#d0b850"
      }
    },
    {
      "name": "Builtin / Special",
      "scope": ["support.function.builtin", "variable.language"],
      "settings": {
        "foreground": "#b8a038"
      }
    },
    {
      "name": "Operator",
      "scope": ["keyword.operator"],
      "settings": {
        "foreground": "#a0a4b8"
      }
    },
    {
      "name": "Punctuation",
      "scope": ["punctuation", "meta.brace"],
      "settings": {
        "foreground": "#a0a4b8"
      }
    },
    {
      "name": "Tag",
      "scope": ["entity.name.tag"],
      "settings": {
        "foreground": "#1a8a6a"
      }
    },
    {
      "name": "Tag Attribute",
      "scope": ["entity.other.attribute-name"],
      "settings": {
        "foreground": "#2aaab8"
      }
    },
    {
      "name": "Decorator / Annotation",
      "scope": ["meta.decorator", "punctuation.decorator", "entity.name.function.decorator"],
      "settings": {
        "foreground": "#583090"
      }
    },
    {
      "name": "Invalid / Illegal",
      "scope": ["invalid.illegal"],
      "settings": {
        "foreground": "#c04050"
      }
    },
    {
      "name": "Markup Heading",
      "scope": ["markup.heading", "entity.name.section"],
      "settings": {
        "foreground": "#e0e2ea",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markup Bold",
      "scope": ["markup.bold"],
      "settings": {
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markup Italic",
      "scope": ["markup.italic"],
      "settings": {
        "fontStyle": "italic"
      }
    },
    {
      "name": "Markup Inline Code",
      "scope": ["markup.inline.raw", "markup.fenced_code.block"],
      "settings": {
        "foreground": "#b8a038"
      }
    },
    {
      "name": "Namespace",
      "scope": ["entity.name.namespace", "entity.name.module"],
      "settings": {
        "foreground": "#2aaab8"
      }
    },
    {
      "name": "Escape Character",
      "scope": ["constant.character.escape"],
      "settings": {
        "foreground": "#d0b850"
      }
    }
  ]
}
