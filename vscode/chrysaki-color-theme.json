  "tokenColors": [
    {
      "name": "Comment",
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": {
        "foreground": "#6a6e8299",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Keyword / Control Flow",
      "scope": ["keyword", "keyword.control", "storage.modifier", "keyword.other.using", "keyword.other.directive"],
      "settings": {
        "foreground": "#7a52b3"
      }
    },
    {
      "name": "Storage Type",
      "scope": ["storage", "storage.type"],
      "settings": {
        "foreground": "#7a52b3"
      }
    },
    {
      "name": "Function / Method",
      "scope": ["entity.name.function", "meta.function-call", "support.function"],
      "settings": {
        "foreground": "#1a8a6a"
      }
    },
    {
      "name": "Type / Class",
      "scope": ["entity.name.type", "entity.name.class", "entity.other.inherited-class", "support.type", "support.class"],
      "settings": {
        "foreground": "#20969c"
      }
    },
    {
      "name": "Variable",
      "scope": ["variable", "variable.other"],
      "settings": {
        "foreground": "#e0e2ea"
      }
    },
    {
      "name": "Parameter",
      "scope": ["variable.parameter"],
      "settings": {
        "foreground": "#20969c"
      }
    },
    {
      "name": "String",
      "scope": ["string", "string.quoted"],
      "settings": {
        "foreground": "#FBB13Ccc"
      }
    },
    {
      "name": "Number",
      "scope": ["constant.numeric"],
      "settings": {
        "foreground": "#FCC96A"
      }
    },
    {
      "name": "Constant / Builtin",
      "scope": ["constant.other", "constant.language", "support.constant", "variable.other.constant"],
      "settings": {
        "foreground": "#FCC96A"
      }
    },
    {
      "name": "Builtin / Special",
      "scope": ["support.function.builtin", "variable.language"],
      "settings": {
        "foreground": "#FBB13C"
      }
    },
    {
      "name": "Operator",
      "scope": ["keyword.operator"],
      "settings": {
        "foreground": "#a0a4b8cc"
      }
    },
    {
      "name": "Punctuation",
      "scope": ["punctuation", "meta.brace"],
      "settings": {
        "foreground": "#a0a4b8cc"
      }
    },
    {
      "name": "Tag",
      "scope": ["entity.name.tag"],
      "settings": {
        "foreground": "#1a8a6a"
      }
    },
    {
      "name": "Tag Attribute",
      "scope": ["entity.other.attribute-name"],
      "settings": {
        "foreground": "#20969c"
      }
    },
    {
      "name": "Decorator / Annotation",
      "scope": ["meta.decorator", "punctuation.decorator", "entity.name.function.decorator"],
      "settings": {
        "foreground": "#7a52b3"
      }
    },
    {
      "name": "Invalid / Illegal",
      "scope": ["invalid.illegal"],
      "settings": {
        "foreground": "#b53f4a"
      }
    },
    {
      "name": "Markup Heading",
      "scope": ["markup.heading", "entity.name.section"],
      "settings": {
        "foreground": "#e0e2ea",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markup Bold",
      "scope": ["markup.bold"],
      "settings": {
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markup Italic",
      "scope": ["markup.italic"],
      "settings": {
        "fontStyle": "italic"
      }
    },
    {
      "name": "Markup Inline Code",
      "scope": ["markup.inline.raw", "markup.fenced_code.block"],
      "settings": {
        "foreground": "#FBB13C"
      }
    },
    {
      "name": "Namespace",
      "scope": ["entity.name.namespace", "entity.name.module"],
      "settings": {
        "foreground": "#20969c"
      }
    },
    {
      "name": "Escape Character",
      "scope": ["constant.character.escape"],
      "settings": {
        "foreground": "#FCC96A"
      }
    }
  ]
}
