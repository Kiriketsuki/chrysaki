{"type":"assistant","message":{"model":"claude-sonnet-4-6","id":"msg_01PqhnJrm8wvPX7rmWnSgzPV","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_016kmd5qsodjLzgRzpkM3zdR","name":"Write","input":{"file_path":"/home/kiriketsuki/dots/chrysaki-ralph-ags-notification-center-T10/ags/.config/ags/widgets/NotificationToast.tsx","content":"import app from \"ags/gtk4/app\"\nimport { Astal } from \"ags/gtk4\"\nimport GLib from \"gi://GLib\"\nimport AstalNotifd from \"gi://AstalNotifd\"\nimport { notifd } from \"./NotificationCenter\"\n\nconst MAX_VISIBLE = 4\nconst DISMISS_DELAY_MS = 5000\n\n// --- Toast queue state ---\n\nconst activeToasts: AstalNotifd.Notification[] = []\nconst queuedToasts: AstalNotifd.Notification[] = []\nconst _toastListeners: Array<() => void> = []\n\nfunction _notifyToastChange(): void {\n  _toastListeners.forEach((cb) => cb())\n}\n\nfunction onToastChange(cb: () => void): void {\n  _toastListeners.push(cb)\n}\n\nfunction promoteFromQueue(): void {\n  while (queuedToasts.length > 0 && activeToasts.length < MAX_VISIBLE) {\n    const next = queuedToasts.shift()!\n    activeToasts.push(next)\n    scheduleAutoDismiss(next)\n  }\n}\n\nfunction dismissToast(n: AstalNotifd.Notification): void {\n  const idx = activeToasts.indexOf(n)\n  if (idx === -1) return\n  activeToasts.splice(idx, 1)\n  promoteFromQueue()\n  _notifyToastChange()\n}\n\nfunction scheduleAutoDismiss(n: AstalNotifd.Notification): void {\n  GLib.timeout_add(GLib.PRIORITY_DEFAULT, DISMISS_DELAY_MS, () => {\n    dismissToast(n)\n    return GLib.SOURCE_REMOVE\n  })\n}\n\nfunction enqueueToast(n: AstalNotifd.Notification): void {\n  if (notifd.dontDisturb) return\n  if (activeToasts.length < MAX_VISIBLE) {\n    activeToasts.push(n)\n    scheduleAutoDismiss(n)\n    _notifyToastChange()\n  } else {\n    queuedToasts.push(n)\n  }\n}\n\n// New notification → enqueue toast\nnotifd.connect(\"notified\", (_: unknown, id: number) => {\n  const n = notifd.get_notification(id)\n  if (n) enqueueToast(n)\n})\n\n// Notification dismissed externally (e.g. from center panel) → clean up toast\nnotifd.connect(\"resolved\", (_: unknown, id: number) => {\n  const toastIdx = activeToasts.findIndex((t) => t.id === id)\n  if (toastIdx !== -1) {\n    activeToasts.splice(toastIdx, 1)\n    promoteFromQueue()\n    _notifyToastChange()\n  }\n  const queueIdx = queuedToasts.findIndex((t) => t.id === id)\n  if (queueIdx !== -1) queuedToasts.splice(queueIdx, 1)\n})\n\n// --- ToastRow component ---\n\nfunction ToastRow(n: AstalNotifd.Notification) {\n  const isCritical = n.urgency === AstalNotifd.Urgency.CRITICAL\n  return (\n    <box\n      class={`notif-toast${isCritical ? \" notif-toast-critical\" : \"\"}`}\n      orientation={1}\n      spacing={2}\n    >\n      <box class=\"notif-toast-header\" spacing={6}>\n        <label\n          class=\"notif-toast-app\"\n          label={n.appName || \"App\"}\n          halign={1}\n          hexpand\n        />\n        <button\n          class=\"notif-toast-close\"\n          label=\"󰅖\"\n          onClicked={() => dismissToast(n)}\n        />\n      </box>\n      <label\n        class=\"notif-toast-summary\"\n        label={n.summary || \"\"}\n        halign={1}\n        xalign={0}\n        wrap\n      />\n      {n.body && (\n        <label\n          class=\"notif-toast-body\"\n          label={n.body}\n          halign={1}\n          xalign={0}\n          wrap\n          ellipsize={3}\n        />\n      )}\n    </box>\n  )\n}\n\n// --- Toast window ---\n\nexport function NotificationToast() {\n  const { TOP, RIGHT } = Astal.WindowAnchor\n  let listBox: any = null\n  let toastWin: any = null\n\n  function rebuild(): void {\n    if (!listBox) return\n    while (listBox.get_first_child()) {\n      listBox.remove(listBox.get_first_child())\n    }\n    for (const n of activeToasts) {\n      listBox.append(ToastRow(n) as any)\n    }\n    if (toastWin) {\n      toastWin.visible = activeToasts.length > 0\n    }\n  }\n\n  onToastChange(rebuild)\n\n  return (\n    <window\n      name=\"chrysaki-notification-toast\"\n      namespace=\"chrysaki-notification-toast\"\n      visible={false}\n      anchor={TOP | RIGHT}\n      exclusivity={Astal.Exclusivity.IGNORE}\n      marginTop={48}\n      marginRight={8}\n      application={app}\n      $={(win: any) => {\n        toastWin = win\n      }}\n    >\n      <box\n        class=\"notif-toast-list\"\n        orientation={1}\n        spacing={6}\n        $={(self: any) => {\n          listBox = self\n        }}\n      />\n    </window>\n  )\n}\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":8018,"cache_read_input_tokens":55690,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":8018},"output_tokens":9,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"87de7f8a-1210-4ae0-aa43-0a98da4aea22","uuid":"b17e00bc-5c1d-4b72-9dae-898749c55d07"}
