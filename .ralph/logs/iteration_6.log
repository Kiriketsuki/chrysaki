{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_018QpFdUTxQFEpUAhN83BWda","type":"tool_result","content":"     1→/**\n     2→ * ServiceStatus -- icon indicators for OV, GitNexus, Ollama, Syncthing health.\n     3→ * Each service displays its SVG icon via Gio.FileIcon; healthy services show\n     4→ * their accent color, unhealthy ones dim to error red.\n     5→ *\n     6→ * Clicking a service icon opens a popup panel showing status and a toggle\n     7→ * button to start/stop the service (where applicable).\n     8→ */\n     9→import app from \"ags/gtk4/app\"\n    10→import { createComputed } from \"ags\"\n    11→import { createPoll } from \"ags/time\"\n    12→import { execAsync } from \"ags/process\"\n    13→import { Astal } from \"ags/gtk4\"\n    14→import Gio from \"gi://Gio\"\n    15→import GLib from \"gi://GLib?version=2.0\"\n    16→\n    17→const ICON_DIR = `${GLib.get_home_dir()}/.config/ags/icons/hicolor/scalable/status`\n    18→\n    19→interface ServiceDef {\n    20→  readonly name: string\n    21→  readonly iconFile: string\n    22→  readonly interval: number\n    23→  readonly command: string\n    24→  readonly cssOk: string\n    25→  readonly startCmd: string | null\n    26→  readonly stopCmd: string | null\n    27→}\n    28→\n    29→const SERVICES: readonly ServiceDef[] = [\n    30→  {\n    31→    name: \"OpenViking\",\n    32→    iconFile: `${ICON_DIR}/openviking-symbolic.svg`,\n    33→    interval: 5000,\n    34→    command: \"curl -sf http://localhost:1933/health >/dev/null 2>&1 && echo ok || echo fail\",\n    35→    cssOk: \"svc-emerald\",\n    36→    startCmd: \"systemctl --user start openviking\",\n    37→    stopCmd: \"systemctl --user stop openviking\",\n    38→  },\n    39→  {\n    40→    name: \"GitNexus\",\n    41→    iconFile: `${ICON_DIR}/gitnexus-symbolic.svg`,\n    42→    interval: 10000,\n    43→    command:\n    44→      \"/home/kiriketsuki/.nvm/versions/node/v24.14.0/bin/gitnexus status >/dev/null 2>&1 && echo ok || echo fail\",\n    45→    cssOk: \"svc-teal\",\n    46→    startCmd: null,\n    47→    stopCmd: null,\n    48→  },\n    49→  {\n    50→    name: \"Ollama\",\n    51→    iconFile: `${ICON_DIR}/ollama-symbolic.svg`,\n    52→    interval: 10000,\n    53→    command:\n    54→      \"curl -sf http://localhost:11434/api/version >/dev/null 2>&1 && echo ok || echo fail\",\n    55→    cssOk: \"svc-amethyst\",\n    56→    startCmd: \"systemctl start ollama\",\n    57→    stopCmd: \"systemctl stop ollama\",\n    58→  },\n    59→  {\n    60→    name: \"Syncthing\",\n    61→    iconFile: `${ICON_DIR}/syncthing-symbolic.svg`,\n    62→    interval: 15000,\n    63→    command: \"systemctl --user is-active syncthing >/dev/null 2>&1 && echo ok || echo fail\",\n    64→    cssOk: \"svc-blonde\",\n    65→    startCmd: \"systemctl --user start syncthing\",\n    66→    stopCmd: \"systemctl --user stop syncthing\",\n    67→  },\n    68→]\n    69→\n    70→const PANEL_NAME = \"chrysaki-service-panel\"\n    71→\n    72→function togglePanel(): void {\n    73→  const panel = app.get_window(PANEL_NAME)\n    74→  if (panel) {\n    75→    panel.visible = !panel.visible\n    76→  }\n    77→}\n    78→\n    79→function ServiceIcon({ name, iconFile, interval, command, cssOk }: ServiceDef) {\n    80→  const status = createPoll(\"ok\", interval, [\"bash\", \"-c\", command])\n    81→  const isOk = createComputed(() => status().trim() === \"ok\")\n    82→  const gicon = Gio.FileIcon.new(Gio.File.new_for_path(iconFile))\n    83→\n    84→  return (\n    85→    <button\n    86→      class=\"svc-button\"\n    87→      tooltipText={name}\n    88→      onClicked={() => togglePanel()}\n    89→    >\n    90→      <image\n    91→        gicon={gicon}\n    92→        pixelSize={16}\n    93→        class=\"svc-icon\"\n    94→        valign={3}\n    95→        $={(self: any) => {\n    96→          let blinkOn = true\n    97→          GLib.timeout_add(GLib.PRIORITY_DEFAULT, 600, () => {\n    98→            if (!isOk()) {\n    99→              blinkOn = !blinkOn\n   100→              self.set_opacity(blinkOn ? 0.85 : 0.15)\n   101→            } else {\n   102→              self.set_opacity(1.0)\n   103→            }\n   104→            return GLib.SOURCE_CONTINUE\n   105→          })\n   106→        }}\n   107→      />\n   108→    </button>\n   109→  )\n   110→}\n   111→\n   112→function ServiceRow({\n   113→  name,\n   114→  iconFile,\n   115→  interval,\n   116→  command,\n   117→  cssOk,\n   118→  startCmd,\n   119→  stopCmd,\n   120→}: ServiceDef) {\n   121→  const status = createPoll(\"ok\", interval, [\"bash\", \"-c\", command])\n   122→\n   123→  const isHealthy = createComputed(() => status().trim() === \"ok\")\n   124→\n   125→  const statusLabel = createComputed(() =>\n   126→    isHealthy() ? \"Healthy\" : \"Unhealthy\",\n   127→  )\n   128→\n   129→  const statusClass = createComputed(() =>\n   130→    isHealthy() ? \"svc-panel-healthy\" : \"svc-panel-unhealthy\",\n   131→  )\n   132→\n   133→  const toggleLabel = createComputed(() =>\n   134→    isHealthy() ? \"\\u{F04DB}\" : \"\\u{F040A}\", // nf-md-stop / nf-md-play\n   135→  )\n   136→\n   137→  const isToggleable = startCmd !== null && stopCmd !== null\n   138→\n   139→  const gicon = Gio.FileIcon.new(Gio.File.new_for_path(iconFile))\n   140→\n   141→  return (\n   142→    <box class={`svc-panel-row svc-row-${cssOk}`} spacing={8} valign={3}>\n   143→      <image gicon={gicon} pixelSize={18} class={`svc-icon ${cssOk}`} />\n   144→      <label class=\"svc-panel-name\" label={name} hexpand halign={1} />\n   145→      <label class={statusClass} label={statusLabel} />\n   146→      {isToggleable ? (\n   147→        <button\n   148→          class=\"svc-panel-toggle\"\n   149→          label={toggleLabel}\n   150→          onClicked={() => {\n   151→            const cmd = isHealthy() ? stopCmd : startCmd\n   152→            if (cmd) {\n   153→              execAsync([\"bash\", \"-c\", cmd]).catch(console.error)\n   154→            }\n   155→          }}\n   156→        />\n   157→      ) : (\n   158→        <label class=\"svc-panel-no-toggle\" label=\"--\" />\n   159→      )}\n   160→    </box>\n   161→  )\n   162→}\n   163→\n   164→export function ServicePanel() {\n   165→  const { TOP, RIGHT } = Astal.WindowAnchor\n   166→\n   167→  return (\n   168→    <window\n   169→      name={PANEL_NAME}\n   170→      namespace={PANEL_NAME}\n   171→      visible={false}\n   172→      anchor={TOP | RIGHT}\n   173→      exclusivity={Astal.Exclusivity.IGNORE}\n   174→      marginTop={48}\n   175→      marginRight={8}\n   176→      application={app}\n   177→    >\n   178→      <box class=\"svc-panel\" orientation={1} spacing={4}>\n   179→        <label class=\"svc-panel-title\" label={\"\\u{F0614}  Services\"} halign={1} />\n   180→        {SERVICES.map((svc) => ServiceRow(svc))}\n   181→      </box>\n   182→    </window>\n   183→  )\n   184→}\n   185→\n   186→export function ServiceStatus() {\n   187→  return (\n   188→    <box class=\"service-status\" spacing={6} valign={3}>\n   189→      {SERVICES.map((svc) => ServiceIcon(svc))}\n   190→    </box>\n   191→  )\n   192→}\n   193→\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":null,"session_id":"2d0aac43-e9c3-48ce-90f3-09f0a6c21830","uuid":"0cd58763-1126-4248-bb2b-81bd4b9ae261","timestamp":"2026-03-17T11:42:27.537Z","tool_use_result":{"type":"text","file":{"filePath":"/home/kiriketsuki/dots/chrysaki-ralph-ags-notification-center-T12/ags/.config/ags/widgets/ServiceStatus.tsx","content":"/**\n * ServiceStatus -- icon indicators for OV, GitNexus, Ollama, Syncthing health.\n * Each service displays its SVG icon via Gio.FileIcon; healthy services show\n * their accent color, unhealthy ones dim to error red.\n *\n * Clicking a service icon opens a popup panel showing status and a toggle\n * button to start/stop the service (where applicable).\n */\nimport app from \"ags/gtk4/app\"\nimport { createComputed } from \"ags\"\nimport { createPoll } from \"ags/time\"\nimport { execAsync } from \"ags/process\"\nimport { Astal } from \"ags/gtk4\"\nimport Gio from \"gi://Gio\"\nimport GLib from \"gi://GLib?version=2.0\"\n\nconst ICON_DIR = `${GLib.get_home_dir()}/.config/ags/icons/hicolor/scalable/status`\n\ninterface ServiceDef {\n  readonly name: string\n  readonly iconFile: string\n  readonly interval: number\n  readonly command: string\n  readonly cssOk: string\n  readonly startCmd: string | null\n  readonly stopCmd: string | null\n}\n\nconst SERVICES: readonly ServiceDef[] = [\n  {\n    name: \"OpenViking\",\n    iconFile: `${ICON_DIR}/openviking-symbolic.svg`,\n    interval: 5000,\n    command: \"curl -sf http://localhost:1933/health >/dev/null 2>&1 && echo ok || echo fail\",\n    cssOk: \"svc-emerald\",\n    startCmd: \"systemctl --user start openviking\",\n    stopCmd: \"systemctl --user stop openviking\",\n  },\n  {\n    name: \"GitNexus\",\n    iconFile: `${ICON_DIR}/gitnexus-symbolic.svg`,\n    interval: 10000,\n    command:\n      \"/home/kiriketsuki/.nvm/versions/node/v24.14.0/bin/gitnexus status >/dev/null 2>&1 && echo ok || echo fail\",\n    cssOk: \"svc-teal\",\n    startCmd: null,\n    stopCmd: null,\n  },\n  {\n    name: \"Ollama\",\n    iconFile: `${ICON_DIR}/ollama-symbolic.svg`,\n    interval: 10000,\n    command:\n      \"curl -sf http://localhost:11434/api/version >/dev/null 2>&1 && echo ok || echo fail\",\n    cssOk: \"svc-amethyst\",\n    startCmd: \"systemctl start ollama\",\n    stopCmd: \"systemctl stop ollama\",\n  },\n  {\n    name: \"Syncthing\",\n    iconFile: `${ICON_DIR}/syncthing-symbolic.svg`,\n    interval: 15000,\n    command: \"systemctl --user is-active syncthing >/dev/null 2>&1 && echo ok || echo fail\",\n    cssOk: \"svc-blonde\",\n    startCmd: \"systemctl --user start syncthing\",\n    stopCmd: \"systemctl --user stop syncthing\",\n  },\n]\n\nconst PANEL_NAME = \"chrysaki-service-panel\"\n\nfunction togglePanel(): void {\n  const panel = app.get_window(PANEL_NAME)\n  if (panel) {\n    panel.visible = !panel.visible\n  }\n}\n\nfunction ServiceIcon({ name, iconFile, interval, command, cssOk }: ServiceDef) {\n  const status = createPoll(\"ok\", interval, [\"bash\", \"-c\", command])\n  const isOk = createComputed(() => status().trim() === \"ok\")\n  const gicon = Gio.FileIcon.new(Gio.File.new_for_path(iconFile))\n\n  return (\n    <button\n      class=\"svc-button\"\n      tooltipText={name}\n      onClicked={() => togglePanel()}\n    >\n      <image\n        gicon={gicon}\n        pixelSize={16}\n        class=\"svc-icon\"\n        valign={3}\n        $={(self: any) => {\n          let blinkOn = true\n          GLib.timeout_add(GLib.PRIORITY_DEFAULT, 600, () => {\n            if (!isOk()) {\n              blinkOn = !blinkOn\n              self.set_opacity(blinkOn ? 0.85 : 0.15)\n            } else {\n              self.set_opacity(1.0)\n            }\n            return GLib.SOURCE_CONTINUE\n          })\n        }}\n      />\n    </button>\n  )\n}\n\nfunction ServiceRow({\n  name,\n  iconFile,\n  interval,\n  command,\n  cssOk,\n  startCmd,\n  stopCmd,\n}: ServiceDef) {\n  const status = createPoll(\"ok\", interval, [\"bash\", \"-c\", command])\n\n  const isHealthy = createComputed(() => status().trim() === \"ok\")\n\n  const statusLabel = createComputed(() =>\n    isHealthy() ? \"Healthy\" : \"Unhealthy\",\n  )\n\n  const statusClass = createComputed(() =>\n    isHealthy() ? \"svc-panel-healthy\" : \"svc-panel-unhealthy\",\n  )\n\n  const toggleLabel = createComputed(() =>\n    isHealthy() ? \"\\u{F04DB}\" : \"\\u{F040A}\", // nf-md-stop / nf-md-play\n  )\n\n  const isToggleable = startCmd !== null && stopCmd !== null\n\n  const gicon = Gio.FileIcon.new(Gio.File.new_for_path(iconFile))\n\n  return (\n    <box class={`svc-panel-row svc-row-${cssOk}`} spacing={8} valign={3}>\n      <image gicon={gicon} pixelSize={18} class={`svc-icon ${cssOk}`} />\n      <label class=\"svc-panel-name\" label={name} hexpand halign={1} />\n      <label class={statusClass} label={statusLabel} />\n      {isToggleable ? (\n        <button\n          class=\"svc-panel-toggle\"\n          label={toggleLabel}\n          onClicked={() => {\n            const cmd = isHealthy() ? stopCmd : startCmd\n            if (cmd) {\n              execAsync([\"bash\", \"-c\", cmd]).catch(console.error)\n            }\n          }}\n        />\n      ) : (\n        <label class=\"svc-panel-no-toggle\" label=\"--\" />\n      )}\n    </box>\n  )\n}\n\nexport function ServicePanel() {\n  const { TOP, RIGHT } = Astal.WindowAnchor\n\n  return (\n    <window\n      name={PANEL_NAME}\n      namespace={PANEL_NAME}\n      visible={false}\n      anchor={TOP | RIGHT}\n      exclusivity={Astal.Exclusivity.IGNORE}\n      marginTop={48}\n      marginRight={8}\n      application={app}\n    >\n      <box class=\"svc-panel\" orientation={1} spacing={4}>\n        <label class=\"svc-panel-title\" label={\"\\u{F0614}  Services\"} halign={1} />\n        {SERVICES.map((svc) => ServiceRow(svc))}\n      </box>\n    </window>\n  )\n}\n\nexport function ServiceStatus() {\n  return (\n    <box class=\"service-status\" spacing={6} valign={3}>\n      {SERVICES.map((svc) => ServiceIcon(svc))}\n    </box>\n  )\n}\n","numLines":193,"startLine":1,"totalLines":193}}}
