oveToastFromContainer(inVisible)\n  }\n  _queue = _queue.filter((v) => v.id !== id)\n  pump()\n})\n\nexport function NotificationToast() {\n  const { TOP, RIGHT } = Astal.WindowAnchor\n  return (\n    <window\n      namespace=\"chrysaki-notification-toast\"\n      anchor={TOP | RIGHT}\n      exclusivity={Astal.Exclusivity.IGNORE}\n      marginTop={48}\n      marginRight={8}\n      visible={false}\n      application={app}\n      $={(win: any) => {\n        _window = win\n      }}\n    >\n      <box\n        class=\"notif-toast-stack\"\n        orientation={1}\n        spacing={6}\n        $={(box: any) => {\n          _container = box\n        }}\n      />\n    </window>\n  )\n}\n","structuredPatch":[{"oldStart":28,"oldLines":7,"newStart":28,"newLines":7,"lines":["     >","       <box class=\"notif-toast-header\" spacing={6}>","         <label","-          class=\"notif-row-app\"","+          class=\"notif-toast-app\"","           label={n.appName || \"App\"}","           halign={1}","           hexpand"]}],"userModified":false,"replaceAll":false}}
