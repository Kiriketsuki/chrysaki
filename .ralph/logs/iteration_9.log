 64→.notif-dnd-btn {\n    65→  background: transparent;\n    66→  border: none;\n    67→  color: $text-secondary;\n    68→  font-size: 16px;\n    69→  padding: 2px 4px;\n    70→  min-width: 0px;\n    71→\n    72→  &:hover {\n    73→    color: $text-primary;\n    74→  }\n    75→}\n    76→\n    77→.notif-dnd-active {\n    78→  color: $blonde-light;\n    79→}\n    80→\n    81→// ============================================================\n    82→// Panel notification list\n    83→// ============================================================\n    84→\n    85→.notif-panel-list {\n    86→  padding: 4px 0px;\n    87→}\n    88→\n    89→.notif-empty {\n    90→  color: $text-muted;\n    91→  font-size: 12px;\n    92→  padding: 16px 0px;\n    93→}\n    94→\n    95→// ============================================================\n    96→// Notification row (chamfered Chrysaki container)\n    97→// clip-path produces the 8px chamfer; borders are omitted as\n    98→// clip-path clips them off — use background tint instead.\n    99→// ============================================================\n   100→\n   101→.notif-row {\n   102→  clip-path: polygon(\n   103→    8px 0%,\n   104→    calc(100% - 8px) 0%,\n   105→    100% 8px,\n   106→    100% calc(100% - 8px),\n   107→    calc(100% - 8px) 100%,\n   108→    8px 100%,\n   109→    0% calc(100% - 8px),\n   110→    0% 8px\n   111→  );\n   112→  background: rgba(255, 255, 255, 0.04);\n   113→  padding: 8px 12px;\n   114→\n   115→  &:hover {\n   116→    background: rgba(255, 255, 255, 0.07);\n   117→  }\n   118→}\n   119→\n   120→// Urgency modifier: critical notifications get Error red tint\n   121→.notif-row-critical {\n   122→  background: rgba(140, 47, 57, 0.15);\n   123→\n   124→  &:hover {\n   125→    background: rgba(140, 47, 57, 0.25);\n   126→  }\n   127→\n   128→  .notif-row-app {\n   129→    color: $blonde-light;\n   130→  }\n   131→}\n   132→\n   133→.notif-row-header {\n   134→  margin-bottom: 2px;\n   135→}\n   136→\n   