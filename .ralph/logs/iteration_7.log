 onUnreadChange, toggleNotificationCenter } from \"./NotificationCenter\"\n\nexport function NotificationToggle() {\n  return (\n    <box class=\"notif-toggle-wrap\" valign={3}>\n      <button\n        class=\"utility-button\"\n        label=\"󰂚\"\n        onClicked={() => toggleNotificationCenter()}\n        tooltipText=\"Toggle notifications\"\n      />\n      <label\n        class=\"notif-badge\"\n        visible={false}\n        label=\"\"\n        valign={1}\n        $={(self: any) => {\n          function update() {\n            const count = getUnreadCount()\n            if (count > 0) {\n              self.label = count > 9 ? \"9+\" : String(count)\n              self.visible = true\n            } else {\n              self.label = \"\"\n              self.visible = false\n            }\n          }\n          onUnreadChange(update)\n        }}\n      />\n    </box>\n  )\n}\n","numLines":34,"startLine":1,"totalLines":34}}}
