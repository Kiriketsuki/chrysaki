ode. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":null,"session_id":"6e2d8ffd-8ba7-457f-bbd7-f41fff8acfc6","uuid":"204c55fc-3639-43b1-ace1-1123f36b7074","timestamp":"2026-03-17T12:06:48.188Z","tool_use_result":{"type":"text","file":{"filePath":"/home/kiriketsuki/dots/chrysaki-ralph-ags-notification-center/ags/.config/ags/styles/_notifications.scss","content":"@use \"palette\" as *;\n\n// ============================================================\n// Bar toggle button\n// ============================================================\n\n.notif-toggle-wrap {\n  position: relative;\n}\n\n// Flat-top hexagon badge (Chrysaki status indicator shape)\n.notif-badge {\n  clip-path: polygon(25% 0%, 75% 0%, 100% 50%, 75% 100%, 25% 100%, 0% 50%);\n  background: $error;\n  color: $text-primary;\n  font-size: 9px;\n  font-weight: bold;\n  min-width: 16px;\n  min-height: 16px;\n  padding: 0px 2px;\n}\n\n// ============================================================\n// Panel window (glassmorphism — compositor blur provides depth)\n// ============================================================\n\n.notif-panel {\n  background-color: rgba(15, 17, 23, 0.15);\n  border: 1px solid rgba(255, 255, 255, 0.1);\n  box-shadow: 0 8px 40px rgba(0, 0, 0, 0.5);\n  padding: 10px;\n  min-width: 320px;\n  max-width: 400px;\n}\n\n// --- Panel header ---\n\n.notif-panel-header {\n  border-bottom: 1px solid rgba(255, 255, 255, 0.1);\n  padding-bottom: 6px;\n  margin-bottom: 4px;\n}\n\n.notif-panel-title {\n  color: $text-primary;\n  font-size: 15px;\n  font-weight: bold;\n  padding: 4px 0px;\n}\n\n.notif-clear-all-btn {\n  background: transparent;\n  border: none;\n  color: $text-muted;\n  font-size: 11px;\n  padding: 2px 6px;\n  min-width: 0px;\n\n  &:hover {\n    color: $error;\n  }\n}\n\n.notif-dnd-btn {\n  background: transparent;\n  border: none;\n  color: $text-secondary;\n  font-size: 16px;\n  padding: 2px 4px;\n  min-width: 0px;\n\n  &:hover {\n    color: $text-primary;\n  }\n}\n\n.notif-dnd-active {\n  color: $blonde-light;\n}\n\n// ============================================================\n// Panel notification list\n// ============================================================\n\n.notif-panel-list {\n  padding: 4px 0px;\n}\n\n.notif-empty {\n  color: $text-muted;\n  font-size: 12px;\n  padding: 16px 0px;\n}\n\n// ============================================================\n// Notification row (chamfered Chrysaki container)\n// clip-path produces the 8px chamfer; borders are omitted as\n// clip-path clips them off — use background tint instead.\n// ============================================================\n\n.notif-row {\n  clip-path: polygon(\n    8px 0%,\n    calc(100% - 8px) 0%,\n    100% 8px,\n    100% calc(100% - 8px),\n    calc(100% - 8px) 100%,\n    8px 100%,\n    0% calc(100% - 8px),\n    0% 8px\n  );\n  background: rgba(255, 255, 255, 0.04);\n  padding: 8px 12px;\n\n  &:hover {\n    background: rgba(255, 255, 255, 0.07);\n  }\n}\n\n// Urgency modifier: critical notifications get Error red tint\n.notif-row-critical {\n  background: rgba(140, 47, 57, 0.15);\n\n  &:hover {\n    background: rgba(140, 47, 57, 0.25);\n  }\n\n  .notif-row-app {\n    color: $blonde-light;\n  }\n}\n\n.notif-row-header {\n  margin-bottom: 2px;\n}\n\n.notif-row-app {\n  color: $teal-light;\n  font-size: 11px;\n  font-weight: bold;\n}\n\n.notif-row-time {\n  color: $text-muted;\n  font-size: 10px;\n}\n\n.notif-dismiss-btn {\n  background: transparent;\n  border: none;\n  color: $text-muted;\n  font-size: 12px;\n  padding: 0px 2px;\n  min-width: 0px;\n\n  &:hover {\n    color: $error;\n  }\n}\n\n.notif-row-summary {\n  color: $text-primary;\n  font-size: 13px;\n  font-weight: bold;\n}\n\n.notif-row-body {\n  color: $text-secondary;\n  font-size: 12px;\n  margin-top: 2px;\n}\n\n// ============================================================\n// Notification action buttons\n// ============================================================\n\n.notif-actions {\n  margin-top: 6px;\n  padding-top: 4px;\n  border-top: 1px solid rgba(255, 255, 255, 0.06);\n}\n\n.notif-action-btn {\n  background: rgba(26, 138, 106, 0.15);\n  border: 1px solid rgba(26, 138, 106, 0.3);\n  color: $emerald-light;\n  font-size: 11px;\n  padding: 3px 8px;\n  min-width: 0px;\n\n  &:hover {\n    background: rgba(26, 138, 106, 0.3);\n    border-color: $emerald-light;\n    color: $text-primary;\n  }\n\n  &:active {\n    background: rgba(26, 138, 106, 0.45);\n  }\n}\n\n// ============================================================\n// Toast popup window (layer-shell, TOP | RIGHT anchor)\n// High alpha background: toasts float without compositor blur.\n// ============================================================\n\n.notif-toast-list {\n  padding: 0px;\n}\n\n// Chamfered toast card — matches .notif-row shape at larger scale\n.notif-toast {\n  clip-path: polygon(\n    8px 0%,\n    calc(100% - 8px) 0%,\n    100% 8px,\n    100% calc(100% - 8px),\n    calc(100% - 8px) 100%,\n    8px 100%,\n    0% calc(100% - 8px),\n    0% 8px\n  );\n  background: rgba(28, 31, 43, 0.92); // $surface at high alpha\n  padding: 10px 14px;\n  min-width: 300px;\n  max-width: 380px;\n\n  &:hover {\n    background: rgba(37, 40, 54, 0.95); // $raised at high alpha\n  }\n}\n\n// Urgency modifier: critical toasts get Error red background\n.notif-toast-critical {\n  background: rgba(140, 47, 57, 0.88);\n\n  &:hover {\n    background: rgba(181, 63, 74, 0.92);\n  }\n\n  .notif-toast-app {\n    color: $blonde-light;\n  }\n}\n\n.notif-toast-header {\n  margin-bottom: 3px;\n}\n\n.notif-toast-app {\n  color: $emerald-light;\n  font-size: 11px;\n  font-weight: bold;\n}\n\n.notif-toast-close {\n  background: transparent;\n  border: none;\n  color: $text-muted;\n  font-size: 12px;\n  padding: 0px 2px;\n  min-width: 0px;\n\n  &:hover {\n    color: $error;\n  }\n}\n\n.notif-toast-summary {\n  color: $text-primary;\n  font-size: 13px;\n  font-weight: bold;\n}\n\n.notif-toast-body {\n  color: $text-secondary;\n  font-size: 12px;\n  margin-top: 2px;\n}\n","numLines":280,"startLine":1,"totalLines":280}}}
