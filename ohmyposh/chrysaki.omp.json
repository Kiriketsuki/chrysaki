{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "version": 2,
  "final_space": false,
  "blocks": [
    {
      "type": "prompt",
      "alignment": "left",
      "segments": [
        {
          "type": "session",
          "style": "powerline",
          "powerline_symbol": "î‚¼",
          "foreground": "#e0e2ea",
          "background": "#8C2F39",
          "template": "{{ if .SSHSession }} ïˆ³ {{ .UserName }}@{{ .HostName }} {{ end }}"
        },
        {
          "type": "path",
          "style": "powerline",
          "powerline_symbol": "î‚¼",
          "foreground": "#e0e2ea",
          "background": "#1c3d7a",
          "properties": {
            "style": "agnoster_short",
            "folder_separator_icon": " î‚½ ",
            "home_icon": "~",
            "max_depth": 4
          },
          "template": " ïپ» {{ .Path }} "
        },
        {
          "type": "git",
          "style": "powerline",
          "powerline_symbol": "î‚¼",
          "foreground": "#0f1117",
          "background": "#1a8a6a",
          "background_templates": [
            "{{ if or (.Working.Changed) (.Staging.Changed) (gt .Behind 0) }}#FBB13C{{ end }}"
          ],
          "properties": {
            "fetch_status": true,
            "fetch_stash_count": true,
            "fetch_upstream_icon": true,
            "branch_icon": " î‚  "
          },
          "template": " {{ .UpstreamIcon }}{{ .HEAD }}{{ if gt .Ahead 0 }} ï•œ {{ .Ahead }}{{ end }}{{ if gt .Behind 0 }} ï•„ {{ .Behind }}{{ end }}{{ if .Staging.Changed }} ïپ• {{ .Staging.String }}{{ end }}{{ if .Working.Changed }} ïپھ {{ .Working.String }}{{ end }}{{ if gt .StashCount 0 }} ï€œ {{ .StashCount }}{{ end }} "
        }
      ]
    },
    {
      "type": "rprompt",
      "alignment": "right",
      "segments": [
        {
          "type": "status",
          "style": "powerline",
          "powerline_symbol": "î‚؛",
          "foreground": "#e0e2ea",
          "background": "#8C2F39",
          "properties": {
            "always_enabled": false
          },
          "template": " ï€چ {{ .Code }} "
        },
        {
          "type": "executiontime",
          "style": "powerline",
          "powerline_symbol": "î‚؛",
          "foreground": "#a0a4b8",
          "background": "#252836",
          "properties": {
            "threshold": 2000,
            "style": "roundrock",
            "always_enabled": false
          },
          "template": " ï‰’ {{ .FormattedMs }} "
        },
        {
          "type": "jobs",
          "style": "powerline",
          "powerline_symbol": "î‚؛",
          "foreground": "#a0a4b8",
          "background": "#252836",
          "template": " ï‚… {{ .Jobs }} "
        },
        {
          "type": "python",
          "style": "powerline",
          "powerline_symbol": "î‚؛",
          "foreground": "#0f1117",
          "background": "#197278",
          "properties": {
            "fetch_version": true,
            "display_mode": "context",
            "fetch_virtual_env": true
          },
          "template": " îœ¼ {{ if .Venv }}({{ .Venv }}) {{ end }}{{ .Full }} "
        },
        {
          "type": "node",
          "style": "powerline",
          "powerline_symbol": "î‚؛",
          "foreground": "#0f1117",
          "background": "#197278",
          "properties": {
            "fetch_version": true,
            "display_mode": "context"
          },
          "template": " îœک {{ .Full }} "
        }
      ]
    },
    {
      "type": "prompt",
      "alignment": "left",
      "newline": true,
      "segments": [
        {
          "type": "text",
          "style": "plain",
          "foreground": "#1a8a6a",
          "foreground_templates": [
            "{{ if gt .Code 0 }}#b53f4a{{ end }}"
          ],
          "background": "transparent",
          "template": "â‌¯ "
        }
      ]
    }
  ]
}
